// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Status {
  active
  inactive
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum CourseType {
  core
  elective
}

enum Semester {
  semester1
  semester2
  semester3
  semester4
  semester5
  semester6
  semester7
  semester8
}

enum BatchStatus {
  active
  inactive
  completed
}

enum FacultyStatus {
  active
  inactive
}

enum EnrollmentStatus {
  active
  dropped
  completed
}

enum AttendanceStatus {
  present
  absent
  late
  excused
  holiday
}

enum SessionType {
  regular
  makeup
  special
  exam
  holiday
}

enum DepartmentStatus {
  active
  inactive
  archived
}

enum CalendarEventType {
  semester_start
  semester_end
  holiday
  first_term_start
  first_term_end
  second_term_start
  second_term_end
  exam_preparation
  exam_start
  exam_end
  result_publication
  supplementary_exam
  college_event
  meeting
  other
}

enum NoticeType {
  holiday_notice
  exam_notice
  result_notice
  class_start_notice
  general_notice
}

enum ExamStatus {
  scheduled
  ongoing
  completed
  cancelled
  result_published
}

enum ResultStatus {
  pending
  draft
  verified
  published
  re_evaluation
  final
}

enum ExamCategory {
  regular
  supplementary
}



// ==================== PERMISSION & ROLE ====================
model Permission {
  id          Int              @id @default(autoincrement())
  name        String           @unique
  description String?
  module      String
  action      String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  roles RolePermission[]

  @@map("permissions")
}

model Role {
  id          Int              @id @default(autoincrement())
  name        String           @unique
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  permissions RolePermission[]
  users       User[]

  @@map("roles")
}

model RolePermission {
  id           Int        @id @default(autoincrement())
  roleId       Int
  permissionId Int
  createdAt    DateTime   @default(now())

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

// ==================== USER ====================
model User {
  id                  Int              @id @default(autoincrement())
  email               String           @unique
  password            String
  firstName           String
  lastName            String
  phone               String?
  avatar              String?
  status              UserStatus       @default(ACTIVE)
  emailVerified       DateTime?
  lastLogin           DateTime?
  mustChangePassword  Boolean          @default(false)
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  roleId              Int
  role                Role             @relation(fields: [roleId], references: [id])

  userDepartments     UserDepartment[]
  student             Student?         @relation("UserStudent")
  faculty             Faculty?         @relation("UserFaculty")

  activityLogs        ActivityLog[]
  headedDepartments   Department[]     @relation("DepartmentHead")
  
  // Results
  enteredResults      Result[]         @relation("EnteredResults")
  verifiedResults     Result[]         @relation("VerifiedResults")

  @@map("users")
}

model UserDepartment {
  id           Int        @id @default(autoincrement())
  userId       Int
  departmentId Int
  isPrimary    Boolean    @default(false)
  assignedAt   DateTime   @default(now())
  assignedBy   Int?

  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  faculties    Faculty[]  @relation("FacultyUserDepartment")

  @@unique([userId, departmentId])
  @@map("user_departments")
}

// ==================== STUDENT ====================
model Student {
  id               Int        @id @default(autoincrement())
  name             String
  email            String?    @unique
  phone            String?    @unique
  address          String?
  enrollmentNo     String?    @unique
  rollNo           String?
  dateOfBirth      DateTime?
  gender           String?
  profilePicture   String?
  status           Status     @default(active)
  inactiveDate     DateTime?
  examRollNumber   String?    @unique
  enrollmentDate   DateTime?  @default(now())
  bloodGroup       String?
  guardianName     String?
  guardianContact  String?
  guardianEmail    String?
  emergencyContact String?

  userId           Int?       @unique
  user             User?      @relation("UserStudent", fields: [userId], references: [id])

  batchId          Int?
  batch            Batch?     @relation(fields: [batchId], references: [id])

  departmentId     Int?
  department       Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  attendances      Attendance[]
  attendanceSummaries AttendanceSummary[]
  classroomEnrollments ClassroomEnrollment[]
  results          Result[]

  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  @@index([batchId])
  @@index([enrollmentNo])
}

// ==================== FACULTY ====================
model Faculty {
  id              Int              @id @default(autoincrement())
  name            String
  phone           String?          @unique
  email           String?          @unique
  address         String?
  joinedDate      DateTime         @default(now())
  cv              String?
  designation     String?
  qualification   String?
  specialization  String?
  profilePicture  String?
  status          FacultyStatus    @default(active)

  userId          Int?             @unique
  user            User?            @relation("UserFaculty", fields: [userId], references: [id])

  userDepartmentId Int?
  userDepartment   UserDepartment? @relation("FacultyUserDepartment", fields: [userDepartmentId], references: [id])

  classrooms      Classroom[]
  classSessions   ClassSession[]

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([userDepartmentId])
}

// ==================== DEPARTMENT ====================
model Department {
  id              Int              @id @default(autoincrement())
  name            String           @unique
  code            String?          @unique
  description     String?
  status          DepartmentStatus @default(active)
  headId          Int?
  head            User?            @relation("DepartmentHead", fields: [headId], references: [id], onDelete: SetNull)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  userDepartments UserDepartment[]
  students        Student[]
  courseLists     CourseList[]
  courses         Course[]
  batches         Batch[]
  classrooms      Classroom[]
  exams           Exam[]

  @@map("departments")
}

// ==================== COURSE ====================
model Course {
  id              Int              @id @default(autoincrement())
  name            String
  code            String           @unique
  credits         Int?
  description     String?
  lecture         Int?
  tutorial        Int?
  practical       Int?
  noncredit       Boolean          @default(false)
  courseType      CourseType       @default(core)
  semester        Semester         @default(semester1)
  syllabus        String?

  departmentId    Int?
  department      Department?      @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  courseLists     CourseList[]
  classrooms      Classroom[]
  results         Result[]

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([departmentId])
  @@index([code])
}

model CourseList {
  id              Int              @id @default(autoincrement())

  departmentId    Int
  department      Department       @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  batchId         Int
  batch           Batch            @relation(fields: [batchId], references: [id], onDelete: Cascade)

  courseId        Int
  course          Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)

  semester        Semester         @default(semester1)
  isActive        Boolean          @default(true)

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@unique([batchId, courseId, semester])
  @@index([batchId])
  @@index([courseId])
  @@index([semester])
}

// ==================== BATCH ====================
model Batch {
  id          Int          @id @default(autoincrement())
  name        String       @unique
  startDate   DateTime
  endDate     DateTime
  status      BatchStatus  @default(active)

  departments Department[]
  courseLists CourseList[]
  students    Student[]
  classrooms  Classroom[]
  batchPreference BatchPreference?
  calendars   AcademicCalendar[]
  exams       Exam[]
  terminalConfig TerminalConfig?

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([name])
}

// ==================== CLASSROOM ====================
model Classroom {
  id              Int              @id @default(autoincrement())
  name            String
  code            String?
  capacity        Int?
  status          String           @default("inactive")
  semester        String?          @default("semester1")

  batchId         Int
  batch           Batch            @relation(fields: [batchId], references: [id], onDelete: Cascade)

  departmentId    Int?
  department      Department?      @relation(fields: [departmentId], references: [id])

  courseId        Int?
  course          Course?          @relation(fields: [courseId], references: [id])

  facultyId       Int?
  faculty         Faculty?         @relation(fields: [facultyId], references: [id], onDelete: SetNull)

  attendances     Attendance[]
  attendanceSummaries AttendanceSummary[]
  classSessions   ClassSession[]
  enrollments     ClassroomEnrollment[]
  calendarEvents  CalendarEvent[]
  exams           Exam[]
  results         Result[]

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([batchId])
  @@index([facultyId])
  @@index([courseId])
  @@index([departmentId])
}

model ClassroomEnrollment {
  id              Int              @id @default(autoincrement())
  studentId       Int
  classroomId     Int
  enrolledAt      DateTime         @default(now())
  status          EnrollmentStatus @default(active)

  student         Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  classroom       Classroom        @relation(fields: [classroomId], references: [id], onDelete: Cascade)

  @@unique([studentId, classroomId])
  @@index([classroomId])
  @@index([studentId])
}

// ==================== ATTENDANCE ====================
model Attendance {
  id              Int              @id @default(autoincrement())
  status          AttendanceStatus @default(present)
  checkInTime     DateTime?
  checkOutTime    DateTime?
  remarks         String?
  markedBy        Int?
  markedAt        DateTime         @default(now())

  studentId       Int
  student         Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)

  classSessionId  Int
  classSession    ClassSession     @relation(fields: [classSessionId], references: [id], onDelete: Cascade)

  classroomId     Int
  classroom       Classroom        @relation(fields: [classroomId], references: [id], onDelete: Cascade)

  @@unique([studentId, classSessionId])
  @@index([studentId])
  @@index([classSessionId])
  @@index([classroomId])
  @@index([status])
}

model AttendanceSummary {
  id              Int              @id @default(autoincrement())
  studentId       Int
  classroomId     Int
  totalSessions   Int              @default(0)
  presentCount    Int              @default(0)
  absentCount     Int              @default(0)
  lateCount       Int              @default(0)
  excusedCount    Int              @default(0)
  percentage      Float            @default(0)
  lastUpdated     DateTime         @default(now())

  student         Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  classroom       Classroom        @relation(fields: [classroomId], references: [id], onDelete: Cascade)

  @@unique([studentId, classroomId])
  @@index([studentId])
  @@index([classroomId])
  @@index([percentage])
}

model ClassSession {
  id              Int              @id @default(autoincrement())
  title           String
  date            DateTime         @default(now())
  startTime       DateTime?
  endTime         DateTime?
  syllabusCovered String?
  notes           String?
  materialUrl     String?
  sessionType     SessionType      @default(regular)

  classroomId     Int
  classroom       Classroom        @relation(fields: [classroomId], references: [id], onDelete: Cascade)

  facultyId       Int?
  faculty         Faculty?         @relation(fields: [facultyId], references: [id], onDelete: SetNull)

  attendances     Attendance[]

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@unique([classroomId, date, startTime])
  @@index([date])
  @@index([classroomId, date])
  @@index([facultyId])
}

// ==================== ACTIVITY LOG ====================
model ActivityLog {
  id        Int      @id @default(autoincrement())
  userId    Int
  action    String
  module    String
  details   Json?
  ipAddress String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("activity_logs")
}

model BatchPreference {
  id              Int      @id @default(autoincrement())
  batchId         Int      @unique
  batch           Batch    @relation(fields: [batchId], references: [id], onDelete: Cascade)
  selectedSemester String?  @default("semester1")
  statusFilter    String?  @default("all")
  classroomStatusFilter   String?
  updatedAt       DateTime @updatedAt
}

// ==================== CALENDAR ====================
model CalendarEvent {
  id            Int      @id @default(autoincrement())
  title         String
  description   String?
  type          String   @default("event")
  date          DateTime
  startTime     String?
  endTime       String?
  isRecurring   Boolean  @default(false)
  recurringDays String[]
  semester      String   @default("all")
  
  classroomId   Int?
  classroom     Classroom? @relation(fields: [classroomId], references: [id])
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@index([classroomId])
  @@index([semester])
  @@index([date])
}

model AcademicCalendar {
  id            Int      @id @default(autoincrement())
  date          DateTime
  description   String
  eventType     CalendarEventType
  semester      Semester?
  batchId       Int?
  batch         Batch?   @relation(fields: [batchId], references: [id])
  notices       CalendarNotice[]
  isAutoGenerated Boolean   @default(false)
  isTermExam      Boolean   @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([date])
  @@index([eventType])
  @@index([batchId])
}

model CalendarNotice {
  id          Int      @id @default(autoincrement())
  calendarId  Int
  calendar    AcademicCalendar @relation(fields: [calendarId], references: [id], onDelete: Cascade)
  noticeType  NoticeType
  title       String
  content     String
  generatedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==================== TERMINAL CONFIG ====================
model TerminalConfig {
  id                Int      @id @default(autoincrement())
  batchId           Int      @unique
  termCount         Int      @default(2)
  termWeeks         String   @default("[7, 12]")
  examDays          Int      @default(5)
  semesterDuration  Int      @default(16)
  updatedAt         DateTime @updatedAt
  
  batch             Batch    @relation(fields: [batchId], references: [id], onDelete: Cascade)
  
  @@map("terminal_configs")
}

// ==================== EXAM & RESULTS ====================
model ExamType {
  id          Int              @id @default(autoincrement())
  name        String           @unique
  code        String           @unique
  description String?
  
  weightage   Float?
  isGraded    Boolean          @default(true)

  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  exams       Exam[]
  results     Result[]
}

model Exam {
  id          Int              @id @default(autoincrement())
  name        String
  
  examTypeId  Int
  examType    ExamType         @relation(fields: [examTypeId], references: [id])

  academicYear String?
  semester    Semester?
  date        DateTime?
  startTime   DateTime?
  endTime     DateTime?

  status      ExamStatus       @default(scheduled)

  departmentId Int?
  department  Department?      @relation(fields: [departmentId], references: [id])

  batchId     Int?
  batch       Batch?           @relation(fields: [batchId], references: [id])

  classroomId Int?
  classroom   Classroom?       @relation(fields: [classroomId], references: [id])

  results     Result[]

  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([examTypeId])
  @@index([departmentId])
  @@index([batchId])
  @@index([classroomId])
  @@index([semester])
  @@index([status])
}

model Result {
  id              Int              @id @default(autoincrement())
  
  studentId       Int
  student         Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  
  classroomId     Int?
  classroom       Classroom?       @relation(fields: [classroomId], references: [id])

  examId          Int?
  exam            Exam?            @relation(fields: [examId], references: [id], onDelete: Cascade)

  examTypeId      Int?
  examType        ExamType?        @relation(fields: [examTypeId], references: [id])

  courseId        Int?
  course          Course?          @relation(fields: [courseId], references: [id])

  examCategory    ExamCategory     @default(regular)
  attempt         Int?
  semester        Semester?

  theoryMarks     Float?
  practicalMarks  Float?
  totalMarks      Float?
  maxMarks        Float?           @default(100)
  passMarks       Float?           @default(40)

  grade           String?
  gradePoint      Float?
  resultStatus    ResultStatus     @default(pending)

  remarks         String?
  isAbsent        Boolean          @default(false)
  isPassed        Boolean?
  examRollNumber  String?
  resultDate      DateTime?
  
  enteredBy       Int?
  enteredByUser   User?            @relation("EnteredResults", fields: [enteredBy], references: [id])
  verifiedBy      Int?
  verifiedByUser  User?            @relation("VerifiedResults", fields: [verifiedBy], references: [id])
  verifiedAt      DateTime?
  
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@unique([studentId, courseId, examCategory, attempt], name: "unique_result_per_attempt")
  @@index([studentId])
  @@index([examId])
  @@index([classroomId])
  @@index([resultStatus])
  @@index([examCategory])
  @@index([semester])
  @@index([attempt])
  @@index([examTypeId])
  @@index([courseId])
}